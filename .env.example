# =============================================================================
# .env.example — Variables de entorno requeridas
# hubspot-sap-integration (Química Sur)
# =============================================================================
# Copia este archivo a .env y completa los valores reales.
# El archivo .env está en .gitignore y NUNCA debe subirse al repositorio.
# =============================================================================

# --- Base de datos (Railway PostgreSQL 16) ---
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- Caché y cola de trabajos (Railway Redis 7) ---
# Formato: redis://HOST:PORT o rediss://HOST:PORT (TLS)
REDIS_URL=redis://host:6379

# --- HubSpot Private App ---
# Token de acceso de la app privada (comienza con "pat-")
HUBSPOT_ACCESS_TOKEN=pat-na1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Secret del cliente para verificar firma HMAC-SHA256 de webhooks
HUBSPOT_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- SAP S/4HANA Cloud ---
# URL base del API OData v2 (sin barra final)
SAP_BASE_URL=https://my426851-api.s4hana.cloud.sap/sap/opu/odata/sap
# Usuario de integración
SAP_USERNAME=CPI_INTEGRATIONS
# Contraseña del usuario de integración
SAP_PASSWORD=your_sap_password_here
# Código de la empresa SAP (Química Sur = 4610)
SAP_COMPANY_CODE=4610
# Agrupación de Business Partners (Química Sur = BP02)
SAP_BP_GROUPING=BP02
# Código de idioma para correspondencia (ISO 2 letras)
SAP_CORRESPONDENCE_LANGUAGE=ES

# --- Aplicación ---
# Entorno de ejecución: development | production | test
NODE_ENV=development
# Puerto del servidor Express
PORT=3000
# Tiempo máximo de bloqueo anti-bucle en milisegundos (30 segundos)
SYNC_LOCK_TIMEOUT_MS=30000
# Número máximo de reintentos por job fallido
MAX_RETRY_ATTEMPTS=5
