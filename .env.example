# =============================================================================
# .env.example — Variables de entorno requeridas
# hubspot-sap-integration (Química Sur)
# =============================================================================
# Copia este archivo a .env y completa los valores reales.
# El archivo .env está en .gitignore y NUNCA debe subirse al repositorio.
# =============================================================================

# --- Base de datos (Railway PostgreSQL 16) ---
DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- Caché y cola de trabajos (Railway Redis 7) ---
REDIS_URL=redis://host:6379

# --- HubSpot Private App ---
HUBSPOT_ACCESS_TOKEN=pat-na1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
HUBSPOT_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- SAP S/4HANA Cloud — Conexión ---
SAP_BASE_URL=https://my426851-api.s4hana.cloud.sap/sap/opu/odata/sap
SAP_USERNAME=CPI_INTEGRATIONS
SAP_PASSWORD=your_sap_password_here

# --- SAP S/4HANA — Business Partner (todos tienen default) ---
SAP_COMPANY_CODE=4610
SAP_BP_GROUPING=BP02
SAP_CORRESPONDENCE_LANGUAGE=ES
# Cuenta contable de conciliación de deudores
SAP_RECONCILIATION_ACCOUNT=10200600
# Tipo de número fiscal: CL1=RUT Chile, AR1D=CUIT Argentina
SAP_TAX_TYPE=CL1
# Roles BP separados por coma: FLCU00=cliente general, FLCU01=cliente ventas
SAP_BP_ROLES=FLCU00,FLCU01
# Condición de pago default: NT00=inmediato, NT30=30 días, NT60=60 días
SAP_DEFAULT_PAYMENT_TERMS=NT30

# --- SAP S/4HANA — Sales Order (todos tienen default) ---
# Tipo de orden: OR=orden estándar
SAP_SALES_ORDER_TYPE=OR
# Organización de ventas: 4601=principal, 4602=secundaria
SAP_SALES_ORGANIZATION=4601
# Canal de distribución
SAP_DISTRIBUTION_CHANNEL=CF
# División/sector
SAP_ORGANIZATION_DIVISION=10
# Material por defecto: Q01=producto químico (L), Q05=otro (L), S001=servicio (H)
SAP_DEFAULT_MATERIAL=Q01
# Unidad de medida: L=litros, KG=kilos, H=horas, UN=unidades
SAP_DEFAULT_MATERIAL_UNIT=L

# --- Defaults generales ---
# Moneda: CLP=peso chileno, USD=dólar
SAP_DEFAULT_CURRENCY=CLP
# País ISO 2 letras
SAP_DEFAULT_COUNTRY=CL

# --- Aplicación ---
NODE_ENV=development
PORT=3000
SYNC_LOCK_TIMEOUT_MS=30000
MAX_RETRY_ATTEMPTS=5
# Intervalo de polling SAP en ms (default: 300000 = 5 min)
SAP_POLL_INTERVAL_MS=300000
